# TODO(SRE): placeholder op:// paths, drafted from services/ocp-relay/config.py + .env.sample
# by matching the vault/item naming convention used in other bcgov 1Password-fed
# vaults.ocp.env files (e.g. bcgov/sbc-pay jobs/ftp-poller, bcgov/namex-search
# namex-solr-importer). Confirm actual vault/item names before this is relied on.

# Keycloak
JWT_OIDC_WELL_KNOWN_CONFIG=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_WELL_KNOWN_CONFIG
JWT_OIDC_ALGORITHMS=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_ALGORITHMS
JWT_OIDC_ISSUER=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_ISSUER
JWT_OIDC_CACHING_ENABLED=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_CACHING_ENABLED
JWT_OIDC_JWKS_CACHE_TIMEOUT=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_JWKS_CACHE_TIMEOUT
JWT_OIDC_AUDIENCE=op://keycloak/$APP_ENV/ocp-relay/JWT_OIDC_AUDIENCE

# SFTP
SFTP_HOST=op://relationship/$APP_ENV/ocp-relay/SFTP_HOST
SFTP_PORT=op://relationship/$APP_ENV/ocp-relay/SFTP_PORT
SFTP_HOST_KEY=op://relationship/$APP_ENV/ocp-relay/SFTP_HOST_KEY
SFTP_USERNAME=op://relationship/$APP_ENV/ocp-relay/SFTP_USERNAME
BCREG_FTP_PRIVATE_KEY=op://relationship/$APP_ENV/ocp-relay/BCREG_FTP_PRIVATE_KEY
BCREG_FTP_PRIVATE_KEY_PASSPHRASE=op://relationship/$APP_ENV/ocp-relay/BCREG_FTP_PRIVATE_KEY_PASSPHRASE

# Pay DB
PAY_DB_NAME=op://database/$APP_ENV/pay-db/DATABASE_NAME
PAY_HOST=op://database/$APP_ENV/pay-db/DATABASE_HOST
PAY_PORT=op://database/$APP_ENV/pay-db/DATABASE_PORT
PAY_USER=op://database/$APP_ENV/pay-db/DATABASE_USERNAME
PAY_PASSWORD=op://database/$APP_ENV/pay-db/DATABASE_PASSWORD

# Colin DB
COLIN_DB_NAME=op://entity/$APP_ENV/colin-api/ORACLE_DB_NAME
COLIN_HOST=op://entity/$APP_ENV/colin-api/ORACLE_HOST
COLIN_PORT=op://entity/$APP_ENV/colin-api/ORACLE_PORT
COLIN_USER=op://entity/$APP_ENV/colin-api/ORACLE_USER
COLIN_PASSWORD=op://entity/$APP_ENV/colin-api/ORACLE_PASSWORD
